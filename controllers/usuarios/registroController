const reenviarCodigoRegistro = (req, res) => {
  const { email } = req.body;

  if (!email) return res.status(400).json({ error: 'Email requerido' });

  // 1. Verificamos que el usuario exista y NO esté verificado aún
  db.query('SELECT * FROM usuarios WHERE Email = ?', [email], (err, results) => {
    if (err || results.length === 0) return res.status(404).json({ error: 'Usuario no encontrado' });

    const usuario = results[0];
    if (usuario.verificado) return res.status(400).json({ error: 'Esta cuenta ya está activa' });

    // 2. Generamos nuevo código (6 dígitos) y nueva expiración (1 hora)
    const nuevoCodigo = Math.floor(100000 + Math.random() * 900000).toString();
    const nuevaExpiracion = new Date(Date.now() + 900000);

    // 3. Actualizamos la BD
    db.query(
      'UPDATE usuarios SET codigoVerificacion = ?, codigoVencimiento = ? WHERE Email = ?',
      [nuevoCodigo, nuevaExpiracion, email],
      async (errUpdate) => {
        if (errUpdate) return res.status(500).json({ error: 'Error al generar nuevo código' });

        // 4. Enviamos el nuevo correo
        try {
          await transporter.sendMail({
            from: `"Equipo TecHub" <${process.env.EMAIL_USER}>`,
            to: email,
            subject: 'Tu nuevo código de verificación - TecHub',
            html: `<p>Hola, aquí tienes tu nuevo código: <b>${nuevoCodigo}</b>. Vence en 1 hora.</p>`
          });
          res.json({ mensaje: 'Se ha enviado un nuevo código a tu correo.' });
        } catch (mailErr) {
          res.status(500).json({ error: 'Error al enviar el correo' });
        }
      }
    );
  });
};

const eliminarUsuario = async (req, res) => {
  const { id } = req.params;

  console.log(`>>> PETICIÓN PARA ELIMINAR USUARIO ID: ${id}`);

  // Consulta SQL para eliminar al usuario
  const sql = 'DELETE FROM usuarios WHERE UsuarioID = ?';

  db.query(sql, [id], (err, result) => {
    if (err) {
      console.error('❌ ERROR MYSQL AL ELIMINAR:', err.sqlMessage);
      
      // Si el usuario tiene productos u órdenes, MySQL podría bloquear el borrado por seguridad.
      if (err.code === 'ER_ROW_IS_REFERENCED_2') {
        return res.status(400).json({ error: 'No puedes eliminar tu cuenta porque tienes productos u órdenes activas.' });
      }

      return res.status(500).json({ error: 'Error interno de la base de datos' });
    }

    if (result.affectedRows === 0) {
      return res.status(404).json({ error: 'Usuario no encontrado' });
    }

    console.log("✅ Cuenta eliminada exitosamente de la BD");
    res.status(200).json({ mensaje: 'Cuenta eliminada exitosamente' });
  });
};



