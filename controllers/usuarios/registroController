const db = require('../../config/db');
const bcrypt = require('bcrypt');
const transporter = require('../../config/mailer');

const crearUsuario = async (req, res) => {
  // 👇 1. Agregamos el telefono aquí
  const { nombre, apellidos, email, password, rolID, telefono } = req.body;

  // 👇 2. Validamos que el telefono no venga vacío
  if (!nombre || !apellidos || !email || !password || !rolID || !telefono) {
    return res.status(400).json({ error: 'Faltan datos obligatorios, incluyendo el teléfono' });
  }

  // 3. Validar que el correo sea institucional
  if (!email.endsWith('@estudiantec.cr')) {
    return res.status(400).json({ error: 'Solo se permiten correos institucionales (@estudiantec.cr)' });
  }

  try {
    // 4. Encriptar la contraseña
    const saltRounds = 10;
    const passwordHash = await bcrypt.hash(password, saltRounds);

    // 5. Generar código de verificación de 6 dígitos
    const codigoVerificacion = Math.floor(100000 + Math.random() * 900000).toString();
    
    // 6. Configurar el vencimiento (15 minutos = 900000 milisegundos)
    const codigoVencimiento = new Date(Date.now() + 900000); 

    // 👇 7. Insertamos el Telefono en la base de datos
    const sql = `
      INSERT INTO usuarios
      (Nombre, Apellidos, Email, Password_hash, Telefono, RolID, verificado, codigoVerificacion, codigoVencimiento)
      VALUES (?, ?, ?, ?, ?, ?, false, ?, ?)
    `;

    db.query(
      sql,
      // 👇 Agregamos la variable 'telefono' en el orden correcto
      [nombre, apellidos, email, passwordHash, telefono, rolID, codigoVerificacion, codigoVencimiento],
      async (err, result) => {
        if (err) {
          console.error('Error insertando usuario:', err);
          // Opcional: Manejo de correo duplicado
          if (err.code === 'ER_DUP_ENTRY') {
            return res.status(400).json({ error: 'Este correo ya está registrado' });
          }
          return res.status(500).json({ error: 'Error al registrar el usuario en la base de datos' });
        }

        try {
          const mailOptions = {
            from: `"Equipo TecHub" <${process.env.EMAIL_USER}>`,
            to: email,
            subject: 'Verifica tu cuenta en TecHub',
            html: `
              <h2>¡Hola, ${nombre}! Bienvenido a TecHub.</h2>
              <p>Para activar tu cuenta, por favor ingresa el siguiente código de seguridad de 6 dígitos:</p>
              <h1 style="color: #0056b3; letter-spacing: 5px;">${codigoVerificacion}</h1>
              <p>Este código vencerá en 15 minutos.</p> 
            `
          };

          await transporter.sendMail(mailOptions);

          res.status(201).json({
            mensaje: 'Usuario registrado. Por favor, revisa tu correo institucional para verificar tu cuenta.',
            usuarioID: result.insertId
          });

        } catch (emailError) {
          console.error('Error enviando el correo:', emailError);
          res.status(500).json({ error: 'Usuario creado, pero hubo un error al enviar el correo de verificación' });
        }
      }
    );
  } catch (error) {
    console.error('Error interno:', error);
    res.status(500).json({ error: 'Error interno del servidor' });
  }
};

const editarUsuario = async (req, res) => {
  const { id } = req.params;
  // Extraemos datos sin importar si el front manda 'nombre' o 'Nombre'
  const nombre = req.body.nombre || req.body.Nombre;
  const apellidos = req.body.apellidos || req.body.Apellidos;
  const email = req.body.email || req.body.Email;
  const telefono = req.body.telefono || req.body.Telefono;

  // LOG PARA DEPURAR (Mira tu terminal negra)
  console.log(">>> PETICIÓN DE EDICIÓN RECIBIDA");
  console.log("ID:", id, "Datos:", { nombre, apellidos, email, telefono });

  const sql = `UPDATE usuarios SET Nombre = ?, Apellidos = ?, Email = ?, Telefono = ? WHERE UsuarioID = ?`;

  db.query(sql, [nombre, apellidos, email, telefono, id], (err, result) => {
    if (err) {
      console.error("❌ ERROR MYSQL:", err.sqlMessage);
      return res.status(500).json({ error: err.sqlMessage });
    }
    
    if (result.affectedRows === 0) {
      return res.status(404).json({ error: "Usuario no encontrado con ID: " + id });
    }

    res.status(200).json({ mensaje: "Perfil actualizado" });
  });
};

