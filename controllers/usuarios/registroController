  const sqlBuscar = 'SELECT * FROM usuarios WHERE Email = ?';

  db.query(sqlBuscar, [email], (err, results) => {
    if (err || results.length === 0) {
      return res.status(404).json({ error: 'Usuario no encontrado' });
    }

    const usuario = results[0];

    // 2. Verificar si ya está activa
    // Dependiendo de cómo lea MySQL los booleanos, puede ser 1 o true
    if (usuario.verificado === 1 || usuario.verificado === true) {
      return res.status(400).json({ error: 'Esta cuenta ya se encuentra verificada' });
