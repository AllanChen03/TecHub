const editarContrasena = async (req, res) => {
  const { id } = req.params; // El ID que viene en la URL
  const { oldPassword, newPassword } = req.body; // Lo que manda el formulario

  try {
    // 1. Buscamos el hash de la contraseña actual
    db.query('SELECT Password_hash FROM usuarios WHERE UsuarioID = ?', [id], async (err, results) => {
      if (err || results.length === 0) return res.status(404).json({ error: 'Usuario no encontrado' });

      const hashActual = results[0].Password_hash;

      // 2. Comparamos la contraseña "vieja" que puso el usuario con la de la BD
      const coincide = await bcrypt.compare(oldPassword, hashActual);
      
      if (!coincide) {
        return res.status(400).json({ error: 'La contraseña actual no es correcta' });
      }

      // 3. Si coincide, encriptamos la nueva
      const saltRounds = 10;
      const nuevoHash = await bcrypt.hash(newPassword, saltRounds);

      // 4. Actualizamos
      db.query('UPDATE usuarios SET Password_hash = ? WHERE UsuarioID = ?', [nuevoHash, id], (errUpdate) => {
        if (errUpdate) return res.status(500).json({ error: 'Error al guardar la nueva contraseña' });
        res.json({ mensaje: '¡Contraseña actualizada con éxito!' });
      });
    });
  } catch (e) {
    res.status(500).json({ error: 'Error interno del servidor' });
  }
};

