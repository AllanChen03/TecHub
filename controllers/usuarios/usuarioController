const db = require('../../config/db');
const bcrypt = require('bcrypt');
const jwt = require('jsonwebtoken');
const transporter = require('../../config/mailer');

const login = async (req, res) => {
  const { email, password } = req.body;

  if (!email || !password) {
    return res.status(400).json({ error: 'Se requiere email y contraseña' });
  }

  const sql = 'SELECT * FROM usuarios WHERE Email = ?';

  db.query(sql, [email], async (err, results) => {
    if (err) {
      console.error('Error al iniciar sesión:', err);
      return res.status(500).json({ error: 'Error interno del servidor' });
    }

    if (results.length === 0) {
      return res.status(404).json({ error: 'Usuario no encontrado' });
    }

    const usuario = results[0];

    if (usuario.verificado === 0 || usuario.verificado === false) {
      return res.status(403).json({ error: 'Por favor, verifica tu correo electrónico antes de iniciar sesión.' });
    }

    const passwordCorrecto = await bcrypt.compare(password, usuario.Password_hash);
    
    if (!passwordCorrecto) {
      return res.status(401).json({ error: 'Contraseña incorrecta' });
    }

    const token = jwt.sign(
      { 
        id: usuario.UsuarioID, 
        rol: usuario.RolID 
      },
      process.env.JWT_SECRET, 
      { expiresIn: '2h' }    
    );

    res.json({ 
      mensaje: 'Inicio de sesión exitoso', 
      token: token,
      user: {
        id: usuario.UsuarioID,
        nombre: usuario.Nombre,       // Verifica que sea 'Nombre' con N mayúscula si así está en tu BD
        apellidos: usuario.Apellidos, // Verifica que sea 'Apellidos'
        email: usuario.Email,
        telefono: usuario.Telefono,
        rol: usuario.RolID            // 1 para admin, 2 para estudiante
      }
    });
  });
};

const solicitarRecuperacion = (req, res) => {
  const { email } = req.body;

  if (!email) return res.status(400).json({ error: 'Debes ingresar un correo' });

  // 1. Buscamos si el usuario existe
  db.query('SELECT * FROM usuarios WHERE Email = ?', [email], (err, results) => {
    if (err || results.length === 0) {
      // Por seguridad, a veces se dice "Si el correo existe, se envió el código" 
      // pero para UX, le diremos si no lo encontramos.
      return res.status(404).json({ error: 'Este correo no está registrado en TecHub' });
    }

    // 2. Generamos código y vencimiento (igual que en registro)
    const codigoVerificacion = Math.floor(100000 + Math.random() * 900000).toString();
    const codigoVencimiento = new Date(Date.now() + 3600000); // 1 hora

    // 3. Guardamos el código en la BD
    db.query(
      'UPDATE usuarios SET codigoVerificacion = ?, codigoVencimiento = ? WHERE Email = ?',
      [codigoVerificacion, codigoVencimiento, email],
      async (errUpdate) => {
        if (errUpdate) return res.status(500).json({ error: 'Error interno al generar código' });

        // 4. Enviamos el correo
        try {
          const mailOptions = {
            from: `"Equipo TecHub" <${process.env.EMAIL_USER}>`,
            to: email,
            subject: 'Recuperación de Contraseña - TecHub',
            html: `
              <h2>Recuperación de cuenta</h2>
              <p>Hemos recibido una solicitud para restablecer tu contraseña en TecHub.</p>
              <p>Ingresa el siguiente código de 6 dígitos para continuar:</p>
              <h1 style="color: #0056b3; letter-spacing: 5px;">${codigoVerificacion}</h1>
              <p>Si no solicitaste esto, puedes ignorar este correo.</p>
            `
          };
          await transporter.sendMail(mailOptions);
          res.json({ mensaje: 'Código de recuperación enviado a tu correo' });
        } catch (emailError) {
          console.error(emailError);
          res.status(500).json({ error: 'Error al enviar el correo electrónico' });
        }
      }
    );
  });
};

